---
import BaseLayout from '@/layouts/BaseLayout.astro';
---

<BaseLayout title="Message Sent | Saffron & Salt">
  <main class="pt-32 pb-24 flex items-center justify-center min-h-[70vh]" data-ps="src/pages/success.astro:qag7nh">
    <div class="text-center px-4" data-ps="src/pages/success.astro:pjejka">
      <div class="w-20 h-20 bg-amber-100 text-amber-700 rounded-full flex items-center justify-center mx-auto mb-6" data-ps="src/pages/success.astro:pjejk9">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>
      </div>
      <h1 class="text-3xl md:text-4xl font-serif text-stone-900 mb-4" data-ps="src/pages/success.astro:4xm4ho">Thank You!</h1>
      <p class="text-stone-600 mb-8 text-lg max-w-md mx-auto" data-ps="src/pages/success.astro:mfe1yt">
        Your message has been sent successfully. Our team will get back to you shortly.
      </p>
      <a 
        href="/" 
        class="inline-block bg-stone-900 text-stone-50 py-3 px-8 rounded-lg font-medium hover:bg-stone-800 transition-colors duration-200"
       data-ps="src/pages/success.astro:mnn9zm">
        Back to Home
      </a>
    </div>
  </main>
</BaseLayout>