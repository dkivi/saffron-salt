---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { SITE } from '@/config/site';

const desserts = [
  {
    name: "Dark Chocolate Fondant",
    price: "14",
    description: "Warm molten center, hazelnut praline, salted caramel gelato.",
    image: "https://images.unsplash.com/photo-1762631176828-0df84208e91b?auto=format&w=800&q=80"
  },
  {
    name: "Wild Berry Tart",
    price: "12",
    description: "Buttery shortcrust, crème pâtissière, seasonal forest berries.",
    image: "https://images.unsplash.com/photo-1769434128988-8e216eda17ea?auto=format&w=800&q=80"
  },
  {
    name: "Classic Crème Brûlée",
    price: "11",
    description: "Madagascar vanilla bean custard, caramelized sugar crust.",
    image: "https://images.unsplash.com/photo-1642773296373-34f9cc2f96e7?auto=format&w=800&q=80"
  }
];
---

<BaseLayout title={`Desserts | ${SITE.name}`} description="Indulge in our selection of handcrafted seasonal desserts.">
  <main class="bg-stone-950 pt-32 pb-24" data-ps="src/pages/desserts.astro:k9tta9">
    <div class="max-w-7xl mx-auto px-6" data-ps="src/pages/desserts.astro:6j71kq">
      <div class="text-center mb-16" data-ps="src/pages/desserts.astro:6j71kr">
        <h1 class="text-4xl md:text-6xl font-bold text-stone-50 mb-6 tracking-tight italic" data-ps="src/pages/desserts.astro:gi1olk">Sweet Finales</h1>
        <p class="text-stone-400 max-w-2xl mx-auto text-lg" data-ps="src/pages/desserts.astro:fn3m47">
          Our pastry chef's selection of handcrafted seasonal treats, prepared daily using the finest local ingredients.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-12" data-ps="src/pages/desserts.astro:6j71ks">
        {desserts.map((dessert) => (
          <div class="group" data-ps="src/pages/desserts.astro:6j71kt">
            <div class="overflow-hidden rounded-lg aspect-[4/5] mb-6" data-ps="src/pages/desserts.astro:6j71ku">
              <img 
                src={dessert.image} 
                alt={dessert.name}
                class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy" data-ps="src/pages/desserts.astro:nc1x2k" />
            </div>
            <div class="flex justify-between items-baseline mb-3" data-ps="src/pages/desserts.astro:6j71kv">
              <h3 class="text-2xl font-bold text-stone-100 italic" data-ps="src/pages/desserts.astro:cus5tm">{dessert.name}</h3>
              <span class="text-amber-500 font-bold" data-ps="src/pages/desserts.astro:gzbiea">${dessert.price}</span>
            </div>
            <p class="text-stone-400 leading-relaxed" data-ps="src/pages/desserts.astro:fn3m46">
              {dessert.description}
            </p>
          </div>
        ))}
      </div>

      <div class="mt-24 text-center" data-ps="src/pages/desserts.astro:6j71kw">
        <div class="inline-block p-12 border border-stone-800 rounded-2xl bg-stone-900/50 backdrop-blur-sm" data-ps="src/pages/desserts.astro:6j71kx">
          <h2 class="text-2xl font-bold text-stone-50 mb-4 italic" data-ps="src/pages/desserts.astro:1tmrdz">Coffee & Digestifs</h2>
          <p class="text-stone-400 mb-8 max-w-md mx-auto" data-ps="src/pages/desserts.astro:fn3m45">
            Pair your dessert with our house-roasted coffee or a selection from our cellar of fine dessert wines and liqueurs.
          </p>
          <a href="/#reservations" class="inline-block px-8 py-3 bg-amber-700 text-white font-bold uppercase tracking-widest text-sm rounded-full hover:bg-amber-800 transition-all" data-ps="src/pages/desserts.astro:8j5pef">
            Book a Table
          </a>
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
