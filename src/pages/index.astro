---
import { SITE } from '@/config/site';
import BaseLayout from '@/layouts/BaseLayout.astro';
import HeroSaffron from '@/components/home/HeroSaffron.astro';
import Story from '@/components/home/Story.astro';
import Menu from '@/components/home/Menu.astro';
import Gallery from '@/components/home/Gallery.astro';
import Reservations from '@/components/home/Reservations.astro';
import Location from '@/components/home/Location.astro';
---

<BaseLayout
  title={SITE.title}
  description={SITE.description}
  type="website"
  jsonLd={{
    '@context': 'https://schema.org',
    '@type': 'Restaurant',
    name: SITE.name,
    description: SITE.description,
    url: new URL(Astro.url.pathname, SITE.url).toString(),
    telephone: '+1-555-123-4567',
    address: {
      '@type': 'PostalAddress',
      streetAddress: '123 Culinary Lane',
      addressLocality: 'San Francisco',
      addressRegion: 'CA',
      postalCode: '94103',
      addressCountry: 'US'
    },
    servesCuisine: 'Modern Rustic',
    priceRange: '$$$',
    openingHours: [
      'Tue-Thu 17:00-22:00',
      'Fri-Sat 17:00-23:00',
      'Sun 16:00-21:00'
    ]
  }}
>
  <HeroSaffron />
  <Story />
  <Menu />
  <Gallery />
  <Reservations />
  <Location />
</BaseLayout>
