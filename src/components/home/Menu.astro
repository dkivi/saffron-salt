---
// Saffron & Salt Menu Component
---

<section id="menu" class="py-24 bg-stone-50 text-stone-900" data-ps="src/components/home/Menu.astro:1">
  <div class="max-w-4xl mx-auto px-6 lg:px-8" data-ps="src/components/home/Menu.astro:qhgoph">
    <div class="text-center mb-16" data-ps="src/components/home/Menu.astro:qhgopg">
      <h2 class="text-3xl md:text-5xl font-serif tracking-tight text-stone-900 mb-4" data-ps="src/components/home/Menu.astro:er03um">Seasonal Menu</h2>
      <p class="text-stone-600" data-ps="src/components/home/Menu.astro:v4mbxm">Locally sourced, thoughtfully prepared.</p>
    </div>

    <div class="space-y-16" data-ps="src/components/home/Menu.astro:qhgopf">
      <!-- Starters -->
      <div data-ps="src/components/home/Menu.astro:qhgope">
        <h3 class="text-2xl font-serif text-amber-800 border-b border-stone-200 pb-4 mb-8" data-ps="src/components/home/Menu.astro:tff129">Starters</h3>
        <div class="space-y-8" data-ps="src/components/home/Menu.astro:qhgopd">
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:qhgoor">
