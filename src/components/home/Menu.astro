              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3oi">Wood-Fired Sourdough</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbxn">Whipped cultured butter, smoked sea salt</p>
            </div>
            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51qx">$9</span>
          </div>
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:qhgoop">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:qhgooo">
              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3oj">Heirloom Tomato Tartare</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbxo">Caper vinaigrette, cured egg yolk, crostini</p>
