            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51qw">$16</span>
          </div>
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:qhgoon">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:qhgoom">
              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3ok">Charred Octopus</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbxp">Fingerling potatoes, nduja, preserved lemon</p>
            </div>
            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51qv">$22</span>
          </div>
        </div>
      </div>

      <!-- Mains -->
      <div data-ps="src/components/home/Menu.astro:qhgool">
        <h3 class="text-2xl font-serif text-amber-800 border-b border-stone-200 pb-4 mb-8" data-ps="src/components/home/Menu.astro:tff128">Mains</h3>
        <div class="space-y-8" data-ps="src/components/home/Menu.astro:qhgook">
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:qhgooj">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:qhgooi">
              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3ol">Hand-Cut Pappardelle</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbxq">Wild boar ragu, pecorino romano, sage</p>
