            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51qu">$32</span>
          </div>
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:a0pg5i">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:a0pg5h">
