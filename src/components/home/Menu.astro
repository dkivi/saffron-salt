              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbyd">Confit garlic, bone marrow butter, seasonal greens</p>
            </div>
            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51q7">$65</span>
          </div>
        </div>
      </div>

      <!-- Desserts -->
      <div data-ps="src/components/home/Menu.astro:a0pg5e">
        <h3 class="text-2xl font-serif text-amber-800 border-b border-stone-200 pb-4 mb-8" data-ps="src/components/home/Menu.astro:tff127">Desserts</h3>
        <div class="space-y-8" data-ps="src/components/home/Menu.astro:a0pg5d">
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:a0pg5c">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:a0pg5b">
              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3oo">Olive Oil Cake</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbye">Macerated seasonal berries, mascarpone</p>
            </div>
            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51q6">$12</span>
          </div>
          <div class="flex justify-between items-baseline" data-ps="src/components/home/Menu.astro:a0pg5a">
            <div class="pr-8" data-ps="src/components/home/Menu.astro:a0pg59">
              <h4 class="text-lg font-medium" data-ps="src/components/home/Menu.astro:qxa3pa">Dark Chocolate Nemesis</h4>
              <p class="text-sm text-stone-600 mt-1" data-ps="src/components/home/Menu.astro:v4mbyf">Espresso crema, hazelnut brittle</p>
            </div>
            <span class="text-lg font-medium" data-ps="src/components/home/Menu.astro:ce51q5">$14</span>
          </div>
        </div>
      </div>
