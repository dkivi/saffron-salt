---
// Hero component - customize with your headline, subtext, and CTA
// NOTE: Padding goes on CONTENT container (not section) so backgrounds/images can touch nav
import { SITE } from '@/config/site';
---

<section class="relative min-h-screen flex items-center overflow-hidden" data-ps="src/components/home/Hero.astro:c630f">
  <!-- Background Image -->
  <div class="absolute inset-0 z-0" data-ps="src/components/home/Hero.astro:ecxgfb">
    <img 
      crossorigin="anonymous"
      src="https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=1200&q=80"
      srcset="https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1767500263347-4eef1b448fc2?auto=format&w=1920&q=80 1920w"
      sizes="100vw"
      alt="Moody restaurant interior" 
      class="w-full h-full object-cover"
      loading="eager"
      fetchpriority="high" data-ps="src/components/home/Hero.astro:fibi7y" />
    <div class="absolute inset-0 bg-black/50 backdrop-blur-[2px]" data-ps="src/components/home/Hero.astro:ecxgfc"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 max-w-7xl mx-auto text-center py-8 md:py-20 px-6" data-ps="src/components/home/Hero.astro:ecxgfc">
    <h1 class="hero-animate text-5xl md:text-7xl font-bold mb-6 text-white" data-ps="src/components/home/Hero.astro:p3vdzm">
      Welcome to <span class="text-orange-400" data-ps="src/components/home/Hero.astro:3f6ipg">{SITE.name}</span>
    </h1>
    <p class="hero-animate hero-animate-delay-1 text-xl md:text-2xl mb-8 max-w-3xl mx-auto text-gray-200" data-ps="src/components/home/Hero.astro:ijv6zd">
      {SITE.description}
    </p>
    <a href="#about" class="hero-animate hero-animate-delay-2 inline-block px-8 py-4 rounded-lg font-bold bg-orange-700 text-white hover:bg-orange-800 transition-colors hover-lift" data-ps="src/components/home/Hero.astro:iblyyl">
      Book a Table
    </a>
  </div>
</section>