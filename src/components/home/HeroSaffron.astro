---
import { SITE } from '@/config/site';
---

<section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden" data-ps="src/components/home/HeroSaffron.astro:1">
  <div class="absolute inset-0 z-0" data-ps="src/components/home/HeroSaffron.astro:2">
    <img 
      crossorigin="anonymous"
      src="https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=1200&q=80" 
      srcset="https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=320&q=80 320w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=640&q=80 640w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=768&q=80 768w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=1024&q=80 1024w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=1280&q=80 1280w, https://images.unsplash.com/photo-1708032679611-c73dac72ef09?auto=format&w=1920&q=80 1920w" 
      sizes="100vw"
      alt="Gourmet plating fine dining" 
      class="w-full h-full object-cover brightness-[0.4]"
      loading="eager"
      fetchpriority="high" data-ps="src/components/home/HeroSaffron.astro:n515if" />
  </div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 text-center text-stone-50" data-ps="src/components/home/HeroSaffron.astro:3">
    <span class="hero-animate block text-amber-400 font-bold tracking-widest uppercase mb-4" data-ps="src/components/home/HeroSaffron.astro:4">Welcome to {SITE.name}</span>
    <h1 class="hero-animate hero-animate-delay-1 text-5xl md:text-8xl font-bold mb-8 leading-tight" data-ps="src/components/home/HeroSaffron.astro:5">
      A Culinary Journey Rooted in Tradition
    </h1>
    <p class="hero-animate hero-animate-delay-2 text-xl md:text-2xl mb-12 max-w-3xl mx-auto text-stone-300 font-sans" data-ps="src/components/home/HeroSaffron.astro:6">
      Elevated rustic dining. Honest ingredients, expertly crafted for the modern palate.
    </p>
    <div class="hero-animate hero-animate-delay-3 flex flex-col md:flex-row gap-4 justify-center" data-ps="src/components/home/HeroSaffron.astro:7">
      <a href="/#menu" class="px-8 py-4 bg-amber-700 text-white rounded-full font-bold hover:bg-amber-800 transition-all hover-lift" data-ps="src/components/home/HeroSaffron.astro:8">
        View Menu
      </a>
      <a href="/#reservations" class="px-8 py-4 bg-stone-50 text-stone-900 rounded-full font-bold hover:bg-stone-200 transition-all hover-lift" data-ps="src/components/home/HeroSaffron.astro:9">
        Book a Table
      </a>
    </div>
  </div>
</section>
