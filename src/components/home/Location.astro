<section id="location" class="bg-stone-950 py-24 md:py-32 text-stone-50" data-ps="src/components/home/Location.astro:1">
  <div class="max-w-7xl mx-auto px-6" data-ps="src/components/home/Location.astro:2">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center" data-ps="src/components/home/Location.astro:3">
      <div class="reveal" data-ps="src/components/home/Location.astro:4">
        <h2 class="text-4xl md:text-5xl font-bold mb-10" data-ps="src/components/home/Location.astro:5">Visit Us</h2>
        
        <div class="space-y-12" data-ps="src/components/home/Location.astro:6">
          <div data-ps="src/components/home/Location.astro:7">
            <h3 class="text-amber-500 font-bold uppercase tracking-widest mb-4" data-ps="src/components/home/Location.astro:8">Address</h3>
            <p class="text-xl text-stone-300 font-sans" data-ps="src/components/home/Location.astro:9">
              123 Culinary Lane<br />
              Epicure District, SF 94103
            </p>
          </div>

          <div data-ps="src/components/home/Location.astro:10">
            <h3 class="text-amber-500 font-bold uppercase tracking-widest mb-4" data-ps="src/components/home/Location.astro:11">Hours</h3>
            <div class="grid grid-cols-2 gap-4 text-stone-300 font-sans" data-ps="src/components/home/Location.astro:12">
              <div data-ps="src/components/home/Location.astro:13">
                <p class="font-bold text-stone-100" data-ps="src/components/home/Location.astro:14">Tue – Thu</p>
                <p data-ps="src/components/home/Location.astro:15">5:00 PM – 10:00 PM</p>
              </div>
              <div data-ps="src/components/home/Location.astro:16">
                <p class="font-bold text-stone-100" data-ps="src/components/home/Location.astro:17">Fri – Sat</p>
                <p data-ps="src/components/home/Location.astro:18">5:00 PM – 11:00 PM</p>
              </div>
              <div data-ps="src/components/home/Location.astro:19">
                <p class="font-bold text-stone-100" data-ps="src/components/home/Location.astro:20">Sun</p>
                <p data-ps="src/components/home/Location.astro:21">4:00 PM – 9:00 PM</p>
              </div>
              <div data-ps="src/components/home/Location.astro:22">
                <p class="font-bold text-stone-100" data-ps="src/components/home/Location.astro:23">Mon</p>
                <p data-ps="src/components/home/Location.astro:24">Closed</p>
              </div>
            </div>
          </div>

          <div data-ps="src/components/home/Location.astro:25">
            <h3 class="text-amber-500 font-bold uppercase tracking-widest mb-4" data-ps="src/components/home/Location.astro:26">Contact</h3>
            <p class="text-xl text-stone-300 font-sans" data-ps="src/components/home/Location.astro:27">
              +1 (555) 123-4567<br />
              hello@saffronsalt.com
            </p>
          </div>
        </div>
      </div>

      <div class="reveal-right" data-ps="src/components/home/Location.astro:28">
        <div class="rounded-2xl overflow-hidden shadow-2xl grayscale hover:grayscale-0 transition-all duration-700" data-ps="src/components/home/Location.astro:29">
          <img crossorigin="anonymous" src="https://images.unsplash.com/photo-1766469515855-dc221ac9989e?auto=format&w=1200&q=80" 
            srcset="https://images.unsplash.com/photo-1766469515855-dc221ac9989e?auto=format&w=480&q=80 480w, https://images.unsplash.com/photo-1766469515855-dc221ac9989e?auto=format&w=800&q=80 800w, https://images.unsplash.com/photo-1766469515855-dc221ac9989e?auto=format&w=1200&q=80 1200w"
            sizes="(max-width: 1024px) 100vw, 50vw"
            alt="Restaurant exterior at night" 
            class="w-full aspect-video lg:aspect-square object-cover"
            loading="lazy" data-ps="src/components/home/Location.astro:z2rcy1" />
        </div>
      </div>
    </div>
  </div>
</section>
