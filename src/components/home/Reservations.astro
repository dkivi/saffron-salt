---
---

<section id="reservations" class="py-24 md:py-32 bg-stone-100" data-ps="src/components/home/Reservations.astro:1">
  <div class="max-w-3xl mx-auto px-6" data-ps="src/components/home/Reservations.astro:2">
    <div class="bg-white rounded-3xl shadow-2xl p-8 md:p-12 reveal" data-ps="src/components/home/Reservations.astro:3">
      <div class="text-center mb-10" data-ps="src/components/home/Reservations.astro:4">
        <h2 class="text-3xl md:text-4xl font-bold text-stone-900 mb-4" data-ps="src/components/home/Reservations.astro:5">Reserve Your Table</h2>
        <p class="text-stone-600 font-sans" data-ps="src/components/home/Reservations.astro:6">Join us for an unforgettable dining experience.</p>
      </div>

      <div id="reservation-status" class="hidden mb-6 px-4 py-3 rounded-lg font-sans text-sm" data-ps="src/components/home/Reservations.astro:7"></div>

      <form id="reservation-form" class="grid grid-cols-1 md:grid-cols-2 gap-6" data-ps="src/components/home/Reservations.astro:8">
        <div data-ps="src/components/home/Reservations.astro:9">
          <label for="name" class="block text-sm font-bold text-stone-700 mb-2 uppercase tracking-wider" data-ps="src/components/home/Reservations.astro:10">Full Name</label>
          <input type="text" id="name" name="name" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all outline-none font-sans" placeholder="Jane Doe" data-ps="src/components/home/Reservations.astro:11" />
        </div>
        <div data-ps="src/components/home/Reservations.astro:12">
          <label for="email" class="block text-sm font-bold text-stone-700 mb-2 uppercase tracking-wider" data-ps="src/components/home/Reservations.astro:13">Email Address</label>
          <input type="email" id="email" name="email" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all outline-none font-sans" placeholder="jane@example.com" data-ps="src/components/home/Reservations.astro:14" />
        </div>
        <div data-ps="src/components/home/Reservations.astro:15">
          <label for="date" class="block text-sm font-bold text-stone-700 mb-2 uppercase tracking-wider" data-ps="src/components/home/Reservations.astro:16">Date</label>
          <input type="date" id="date" name="date" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all outline-none font-sans" data-ps="src/components/home/Reservations.astro:17" />
        </div>
        <div data-ps="src/components/home/Reservations.astro:18">
          <label for="time" class="block text-sm font-bold text-stone-700 mb-2 uppercase tracking-wider" data-ps="src/components/home/Reservations.astro:19">Time</label>
          <select id="time" name="time" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all outline-none font-sans" data-ps="src/components/home/Reservations.astro:20">
            <option value="17:00" data-ps="src/components/home/Reservations.astro:21">5:00 PM</option>
            <option value="17:30" data-ps="src/components/home/Reservations.astro:22">5:30 PM</option>
            <option value="18:00" data-ps="src/components/home/Reservations.astro:23">6:00 PM</option>
            <option value="18:30" data-ps="src/components/home/Reservations.astro:24">6:30 PM</option>
            <option value="19:00" data-ps="src/components/home/Reservations.astro:25">7:00 PM</option>
            <option value="19:30" data-ps="src/components/home/Reservations.astro:26">7:30 PM</option>
            <option value="20:00" data-ps="src/components/home/Reservations.astro:27">8:00 PM</option>
            <option value="20:30" data-ps="src/components/home/Reservations.astro:28">8:30 PM</option>
            <option value="21:00" data-ps="src/components/home/Reservations.astro:29">9:00 PM</option>
          </select>
        </div>
        <div class="md:col-span-2" data-ps="src/components/home/Reservations.astro:30">
          <label for="guests" class="block text-sm font-bold text-stone-700 mb-2 uppercase tracking-wider" data-ps="src/components/home/Reservations.astro:31">Number of Guests</label>
          <input type="number" id="guests" name="guests" min="1" max="12" required class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-lg focus:ring-2 focus:ring-amber-500 focus:border-transparent transition-all outline-none font-sans" placeholder="2" data-ps="src/components/home/Reservations.astro:32" />
          <p class="mt-2 text-xs text-stone-500 font-sans" data-ps="src/components/home/Reservations.astro:33">For parties of 8 or more, please contact us directly.</p>
        </div>
        <div class="md:col-span-2 mt-4" data-ps="src/components/home/Reservations.astro:34">
          <button type="submit" id="reservation-submit" class="w-full bg-stone-900 text-white font-bold py-4 rounded-full hover:bg-amber-600 transition-all hover-lift uppercase tracking-widest" data-ps="src/components/home/Reservations.astro:35">
            Request Reservation
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    const form = document.getElementById('reservation-form') as HTMLFormElement;
    const status = document.getElementById('reservation-status') as HTMLDivElement;
    const submitBtn = document.getElementById('reservation-submit') as HTMLButtonElement;

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      submitBtn.disabled = true;
      const originalText = submitBtn.textContent;
      submitBtn.textContent = 'Processing...';

      const formData = new FormData(form);

      try {
        const response = await fetch('/psapi-internal-v1/forms/submit', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            subject: 'New Table Reservation',
            name: formData.get('name'),
            email: formData.get('email'),
            date: formData.get('date'),
            time: formData.get('time'),
            guests: formData.get('guests'),
          }),
        });

        const result = await response.json();

        if (result.success) {
          status.className = 'mb-6 px-4 py-3 rounded-lg bg-stone-900 text-white font-sans text-sm block';
          status.textContent = 'Reservation request sent! We will confirm your table shortly.';
          form.reset();
        } else {
          throw new Error(result.error || 'Failed to send');
        }
      } catch (err) {
        status.className = 'mb-6 px-4 py-3 rounded-lg bg-red-50 border border-red-200 text-red-700 font-sans text-sm block';
        status.textContent = 'Something went wrong. Please try calling us instead.';
      } finally {
        submitBtn.disabled = false;
        submitBtn.textContent = originalText;
      }
    });
  </script>
</section>
