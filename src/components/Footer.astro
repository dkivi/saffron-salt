---
// Footer component - shared across all pages
import { SITE } from '@/config/site';

export interface Props {
  companyName?: string;
  copyright?: string;
}

const {
  companyName = SITE.name,
  copyright = `© ${new Date().getFullYear()} ${companyName}. All rights reserved.`
} = Astro.props;
---

<footer class="bg-stone-950 text-white py-16 px-6 border-t border-stone-900" data-ps="src/components/Footer.astro:1">
  <div class="max-w-7xl mx-auto" data-ps="src/components/Footer.astro:2">
    <div class="grid grid-cols-1 md:grid-cols-3 gap-12 mb-12" data-ps="src/components/Footer.astro:3">
      <!-- Brand -->
      <div data-ps="src/components/Footer.astro:4">
        <h2 class="text-2xl font-bold text-amber-500 mb-6 tracking-tighter" data-ps="src/components/Footer.astro:5">{companyName}</h2>
        <p class="text-sm text-stone-400 font-sans leading-relaxed" data-ps="src/components/Footer.astro:6">
          Elevated rustic dining rooted in tradition. Honest ingredients, expertly crafted for a shared culinary celebration.
        </p>
      </div>

      <!-- Quick Links -->
      <div data-ps="src/components/Footer.astro:7">
        <h2 class="text-sm font-bold text-stone-100 uppercase tracking-widest mb-6" data-ps="src/components/Footer.astro:8">Explore</h2>
        <ul class="list-none p-0 m-0 flex flex-col gap-3">
          <li data-ps="src/components/Footer.astro:9"><a href="/#story" class="text-sm text-stone-400 no-underline hover:text-amber-500 transition-colors font-sans" data-ps="src/components/Footer.astro:10">Our Story</a></li>
          <li data-ps="src/components/Footer.astro:11"><a href="/#menu" class="text-sm text-stone-400 no-underline hover:text-amber-500 transition-colors font-sans" data-ps="src/components/Footer.astro:12">Menu</a></li>
          <li data-ps="src/components/Footer.astro:13"><a href="/#gallery" class="text-sm text-stone-400 no-underline hover:text-amber-500 transition-colors font-sans" data-ps="src/components/Footer.astro:14">Gallery</a></li>
          <li data-ps="src/components/Footer.astro:15"><a href="/#reservations" class="text-sm text-stone-400 no-underline hover:text-amber-500 transition-colors font-sans" data-ps="src/components/Footer.astro:16">Reservations</a></li>
        </ul>
      </div>

      <!-- Social & Info -->
      <div data-ps="src/components/Footer.astro:17">
        <h2 class="text-sm font-bold text-stone-100 uppercase tracking-widest mb-6" data-ps="src/components/Footer.astro:18">Follow Us</h2>
        <div class="flex gap-4 mb-8" data-ps="src/components/Footer.astro:19">
          <a href="#" class="text-stone-400 hover:text-amber-500 transition-colors" aria-label="Instagram" data-ps="src/components/Footer.astro:20">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/></svg>
          </a>
          <a href="#" class="text-stone-400 hover:text-amber-500 transition-colors" aria-label="Twitter" data-ps="src/components/Footer.astro:21">
            <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M23.953 4.57a10 10 0 01-2.825.775 4.958 4.958 0 002.163-2.723c-.951.555-2.005.959-3.127 1.184a4.92 4.92 0 00-8.384 4.482C7.69 8.095 4.067 6.13 1.64 3.162a4.822 4.822 0 00-.666 2.475c0 1.71.87 3.213 2.188 4.096a4.904 4.904 0 01-2.228-.616v.06a4.923 4.923 0 003.946 4.84 4.996 4.996 0 01-2.212.085 4.936 4.936 0 004.604 3.417 9.867 9.867 0 01-6.102 2.105c-.39 0-.779-.023-1.17-.067a13.995 13.995 0 007.557 2.209c9.053 0 13.998-7.496 13.998-13.985 0-.21 0-.42-.015-.63A9.935 9.935 0 0024 4.59z"/></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Copyright -->
    <div class="border-t border-stone-900 pt-8 flex flex-col md:flex-row justify-between items-center gap-4" data-ps="src/components/Footer.astro:22">
      <p class="text-xs text-stone-400 font-sans" data-ps="src/components/Footer.astro:23">{copyright}</p>
      <div class="flex gap-6" data-ps="src/components/Footer.astro:24">
        <a href="#" class="text-xs text-stone-400 hover:text-stone-300 font-sans" data-ps="src/components/Footer.astro:25">Privacy Policy</a>
        <a href="#" class="text-xs text-stone-400 hover:text-stone-300 font-sans" data-ps="src/components/Footer.astro:26">Terms of Service</a>
      </div>
    </div>
  </div>
</footer>
